Algoritmo "positivo, negativo, nulo"
//Desenvolva um programa em VisuAlg que leia um n·mero e determine se ķ positivo, negativo ou nulo.

var
   num: real
inicio
   Escreval("Digite um n·mero: ")
   Leia(num)

   Se (num > 0) entao
      Escreval("O n·mero ķ POSITIVO.")
   Senao
      Se (num < 0) entao
         Escreval("O n·mero ķ NEGATIVO.")
      Senao
         Escreval("O n·mero ķ NULO.")
      Fimse
   Fimse
fimalgoritmo