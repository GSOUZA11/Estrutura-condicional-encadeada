Algoritmo "verifica idade e classifica"
//Desenvolva um programa em VisuAlg que leia a idade e verifique se a pessoa é uma criança, adolescente, jovem adulto, adulto, coroa ou idoso, ainda valide se a idade é válida.

var
   idade: inteiro

inicio
   // Entrada com validaçăo (0 a 100)
   repita
      escreva("Digite a idade (0 a 100): ")
      leia(idade)

      se (idade < 0) ou (idade > 100) entao
         escreval("Idade inválida! Tente novamente.")
      fimse
   ate (idade >= 0) e (idade <= 100)

   // Classificaçăo por faixas
   se (idade <= 11) entao
      escreval("Classificaçăo: CRIANÇA")
   senao
      se (idade <= 17) entao
         escreval("Classificaçăo: ADOLESCENTE")
      senao
         se (idade <= 29) entao
            escreval("Classificaçăo: JOVEM ADULTO")
         senao
            se (idade <= 44) entao
               escreval("Classificaçăo: ADULTO")
            senao
               se (idade <= 59) entao
                  escreval("Classificaçăo: COROA")
               senao
                  escreval("Classificaçăo: IDOSO")
               fimse
            fimse
         fimse
      fimse
   fimse
fimalgoritmo